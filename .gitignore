# Fichier de config sensible (token GitHub)
.env

# Fichiers temporaires de l'updater
_update.zip
_update_tmp/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Environnement virtuel
venv/
env/
.venv/

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db
